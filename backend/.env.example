# Optional: Database connection URL (e.g., postgresql://postgres:postgres@localhost:5432/product_hunt)
# If left empty, SQLite fallback is activated automatically ("sqlite:///./product_hunt.db")
DATABASE_URL=

# Optional: Product Hunt OAuth credentials
# If left empty, the high-fidelity mock seed generator is activated automatically
PRODUCT_HUNT_CLIENT_ID=
PRODUCT_HUNT_CLIENT_SECRET=
